# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# ==========================================================
# SUPABASE DATABASE & AUTHENTICATION CONFIGURATION
# ==========================================================
# Get these settings from your Supabase Project Settings > API.
SUPABASE_URL=""
SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# ==========================================================
# WHATSAPP BUSINESS API CONFIGURATION
# ==========================================================
# Set up your Meta WhatsApp Business app at developers.facebook.com
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_ACCESS_TOKEN=""

# ==========================================================
# SMS CHANNELS GATEWAY (AFRICA'S TALKING OR TWILIO)
# ==========================================================
# Africa's Talking credentials (Primary for Uganda MTN & Airtel)
AFRICASTALKING_USERNAME=""
AFRICASTALKING_API_KEY=""

# Twilio Credentials (Alternative for global coverage)
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM_NUMBER=""

# ==========================================================
# CLOUD SQL POSTGRESQL CONFIGURATION
# ==========================================================
SQL_HOST=""
SQL_USER=""
SQL_PASSWORD=""
SQL_DB_NAME=""
SQL_ADMIN_USER=""
SQL_ADMIN_PASSWORD=""


